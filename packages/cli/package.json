{
  "name": "automagent",
  "version": "0.2.1",
  "description": "CLI toolkit for the automagent agent definition standard",
  "type": "module",
  "bin": {
    "automagent": "dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@automagent/schema": "^0.1.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "open": "^11.0.0",
    "ora": "^8.1.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@types/node": "^22.0.0",
    "openai": "^4.77.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/automagent/automagent.git",
    "directory": "packages/cli"
  },
  "homepage": "https://automagent.dev",
  "bugs": {
    "url": "https://github.com/automagent/automagent/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "yaml",
    "cli",
    "automagent",
    "llm"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
